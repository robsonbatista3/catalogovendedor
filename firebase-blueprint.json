{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users (Admin or Seller)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "vendedor"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Catalog products",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "specifications": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "category", "stock", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Sales orders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientAddress": { "type": "string" },
        "clientPhone": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "productPrice": { "type": "number" },
        "quantity": { "type": "number" },
        "totalAmount": { "type": "number" },
        "vendedorId": { "type": "string" },
        "vendedorName": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] }
      },
      "required": ["id", "clientId", "clientName", "productId", "quantity", "totalAmount", "vendedorId", "orderDate", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Sales orders"
    }
  }
}
